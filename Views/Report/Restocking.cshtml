@model IEnumerable<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Product>
@{
    ViewData["Title"] = "Restocking";
    var suppliers = ViewData["Suppliers"] as List<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Supplier> ?? new List<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Supplier>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Restocking</h1>
        <p class="page-subtitle">Items below minimum stock level that need reordering</p>
    </div>
</div>

@if (Model.Any())
{
    <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr);">
        <div class="stat-card">
            <div class="stat-icon stat-icon-yellow"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="stat-info"><h3>@Model.Count()</h3><p>Items Need Restocking</p></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue"><i class="fas fa-truck"></i></div>
            <div class="stat-info"><h3>@suppliers.Count</h3><p>Active Suppliers</p></div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h2><i class="fas fa-box-open"></i> Restocking Recommendations</h2></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Current Stock</th>
                            <th>Min Stock</th>
                            <th>Need</th>
                            <th>Status</th>
                            <th>Estimated Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            var needed = Math.Max(0, p.MinStock - p.StockQuantity);
                            <tr>
                                <td>
                                    <div class="product-cell">
                                        @if (!string.IsNullOrEmpty(p.ImagePath))
                                        {
                                            <img src="@p.ImagePath" alt="@p.ProductName" class="product-thumb" />
                                        }
                                        else
                                        {
                                            <div class="product-thumb-placeholder"><i class="fas fa-image"></i></div>
                                        }
                                        <span>@p.ProductName</span>
                                    </div>
                                </td>
                                <td>@p.Category</td>
                                <td><strong>@p.StockQuantity</strong></td>
                                <td>@p.MinStock</td>
                                <td><strong class="text-danger">@needed units</strong></td>
                                <td>
                                    <span class="status-badge status-@p.Status.ToLower().Replace(" ", "-")">@p.Status</span>
                                </td>
                                <td>₱@((p.Cost * needed).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (suppliers.Any())
    {
        <div class="card">
            <div class="card-header"><h2><i class="fas fa-truck"></i> Active Suppliers</h2></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="data-table">
                        <thead><tr><th>Supplier</th><th>Contact</th><th>Phone</th><th>Email</th><th>Categories</th></tr></thead>
                        <tbody>
                            @foreach (var s in suppliers)
                            {
                                <tr>
                                    <td><strong>@s.Name</strong></td>
                                    <td>@(s.Contact ?? "—")</td>
                                    <td>@(s.Phone ?? "—")</td>
                                    <td>@(s.Email ?? "—")</td>
                                    <td>@(s.Categories ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="empty-state" style="padding: 60px 20px;">
                <i class="fas fa-check-circle" style="color: var(--success); font-size: 3rem; margin-bottom: 16px;"></i>
                <h3 style="margin-bottom: 8px;">All Stock Levels Are Healthy</h3>
                <p>No items need restocking at this time.</p>
            </div>
        </div>
    </div>
}
