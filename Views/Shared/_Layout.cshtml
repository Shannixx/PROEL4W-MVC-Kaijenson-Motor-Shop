@{
    var userName = Context.Session.GetString("UserName") ?? "User";
    var userRole = Context.Session.GetString("UserRole") ?? "Manager";
    var userImage = Context.Session.GetString("UserImage");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isAdmin = userRole == "Admin";
    var initials = userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : userName.ToUpper();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kaijenson Motor Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js"></script>
</head>
<body>
    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="fas fa-wrench"></i>
            </div>
            <div class="brand-text">
                <h2>Kaijenson</h2>
                <span>Motor Shop</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <p class="nav-section-label">MAIN MENU</p>
            <a href="@Url.Action("Index", "Dashboard")" class="nav-link @(currentController == "Dashboard" ? "active" : "")">
                <i class="fas fa-th-large"></i>
                <span>Dashboard</span>
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Index", "Product")" class="nav-link @(currentController == "Product" ? "active" : "")">
                    <i class="fas fa-boxes-stacked"></i>
                    <span>Inventory</span>
                </a>
            }
            <a href="@Url.Action("Index", "Sale")" class="nav-link @(currentController == "Sale" && currentAction == "Index" ? "active" : "")">
                <i class="fas fa-shopping-cart"></i>
                <span>Point of Sale</span>
            </a>
            <a href="@Url.Action("Orders", "Sale")" class="nav-link @(currentController == "Sale" && currentAction == "Orders" ? "active" : "")">
                <i class="fas fa-clipboard-list"></i>
                <span>Orders</span>
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Index", "Customer")" class="nav-link @(currentController == "Customer" ? "active" : "")">
                    <i class="fas fa-users"></i>
                    <span>Customers</span>
                </a>
            }
            <a href="@Url.Action("Index", "Report")" class="nav-link @(currentController == "Report" && currentAction == "Index" ? "active" : "")">
                <i class="fas fa-chart-bar"></i>
                <span>Reports</span>
            </a>

            @if (isAdmin)
            {
                <p class="nav-section-label mt-4">INVENTORY TOOLS</p>
                <a href="@Url.Action("Index", "StockTransaction")" class="nav-link @(currentController == "StockTransaction" ? "active" : "")">
                    <i class="fas fa-arrow-right-arrow-left"></i>
                    <span>Stock Transactions</span>
                </a>
                <a href="@Url.Action("Index", "Supplier")" class="nav-link @(currentController == "Supplier" ? "active" : "")">
                    <i class="fas fa-truck-field"></i>
                    <span>Suppliers</span>
                </a>
                <a href="@Url.Action("Inventory", "Report")" class="nav-link @(currentController == "Report" && currentAction == "Inventory" ? "active" : "")">
                    <i class="fas fa-chart-pie"></i>
                    <span>Inventory Reports</span>
                </a>
                <a href="@Url.Action("Restocking", "Report")" class="nav-link @(currentController == "Report" && currentAction == "Restocking" ? "active" : "")">
                    <i class="fas fa-boxes-packing"></i>
                    <span>Restocking</span>
                </a>
                <a href="@Url.Action("Sales", "Report")" class="nav-link @(currentController == "Report" && currentAction == "Sales" ? "active" : "")">
                    <i class="fas fa-file-invoice-dollar"></i>
                    <span>Sales Reports</span>
                </a>
            }

            @if (isAdmin)
            {
                <p class="nav-section-label mt-4">ADMIN</p>
                <a href="@Url.Action("Index", "User")" class="nav-link @(currentController == "User" && currentAction != "Profile" && currentAction != "ChangePassword" ? "active" : "")">
                    <i class="fas fa-user-shield"></i>
                    <span>User Management</span>
                </a>
                <a href="@Url.Action("Index", "ActivityLog")" class="nav-link @(currentController == "ActivityLog" ? "active" : "")">
                    <i class="fas fa-clock-rotate-left"></i>
                    <span>Activity Logs</span>
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <a href="@Url.Action("Profile", "User")" class="nav-link @(currentAction == "Profile" || currentAction == "ChangePassword" ? "active" : "")">
                <i class="fas fa-gear"></i>
                <span>Settings</span>
            </a>
            <a href="@Url.Action("Logout", "Account")" class="nav-link logout-link" onclick="return confirm('Are you sure you want to log out?');">
                <i class="fas fa-right-from-bracket"></i>
                <span>Log Out</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Header -->
        <header class="top-header">
            <div class="header-left">
                <button class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="header-search" id="globalSearchWrapper">
                    <i class="fas fa-search"></i>
                    <input type="text" id="globalSearchInput" placeholder="Search products, orders..." autocomplete="off" />
                    <!-- Global Search Results Dropdown -->
                    <div class="global-search-dropdown" id="globalSearchDropdown">
                        <div class="global-search-loading" id="globalSearchLoading" style="display:none;">
                            <i class="fas fa-spinner fa-spin"></i> Searching...
                        </div>
                        <div id="globalSearchResults"></div>
                        <div class="global-search-empty" id="globalSearchEmpty" style="display:none;">
                            <i class="fas fa-search"></i>
                            <p>No results found</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="header-notifications">
                    <button class="notification-btn" id="notificationBell" onclick="toggleNotificationDropdown()">
                        <i class="fas fa-bell"></i>
                        <span class="notification-badge" id="notificationBadge" style="display:none;">0</span>
                    </button>
                    <!-- Notification Dropdown -->
                    <div class="notification-dropdown" id="notificationDropdown">
                        <div class="notification-dropdown-header">
                            <h3>Notifications</h3>
                            <button onclick="markAllNotificationsRead()" class="notification-mark-all">Mark all read</button>
                        </div>
                        <div class="notification-dropdown-body" id="notificationList">
                            <div class="notification-empty">
                                <i class="fas fa-bell-slash"></i>
                                <p>No notifications</p>
                            </div>
                        </div>
                        <div class="notification-dropdown-footer">
                            <span id="notificationSummary">0 notifications</span>
                        </div>
                    </div>
                </div>
                <!-- Profile Dropdown -->
                <div class="header-profile" id="profileDropdownTrigger" onclick="toggleProfileDropdown()">
                    <div class="profile-avatar">
                        @if (!string.IsNullOrEmpty(userImage))
                        {
                            <img src="@userImage" alt="Profile" />
                        }
                        else
                        {
                            <span>@initials</span>
                        }
                    </div>
                    <div class="profile-info">
                        <span class="profile-role">@userRole.ToUpper()</span>
                        <span class="profile-name">@userName</span>
                    </div>
                    <i class="fas fa-chevron-down profile-chevron"></i>
                    <!-- Profile Dropdown Menu -->
                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="profile-dropdown-header">
                            <div class="profile-dropdown-avatar">
                                @if (!string.IsNullOrEmpty(userImage))
                                {
                                    <img src="@userImage" alt="Profile" />
                                }
                                else
                                {
                                    <span>@initials</span>
                                }
                            </div>
                            <div class="profile-dropdown-info">
                                <strong>@userName</strong>
                                <span class="role-badge role-@userRole.ToLower()">@userRole</span>
                            </div>
                        </div>
                        <div class="profile-dropdown-divider"></div>
                        <a href="@Url.Action("Profile", "User")" class="profile-dropdown-item">
                            <i class="fas fa-user"></i>
                            <span>My Profile</span>
                        </a>
                        <a href="@Url.Action("Profile", "User")" class="profile-dropdown-item" onclick="sessionStorage.setItem('openSettingsTab','security')">
                            <i class="fas fa-key"></i>
                            <span>Change Password</span>
                        </a>
                        <a href="@Url.Action("Profile", "User")" class="profile-dropdown-item" onclick="sessionStorage.setItem('openSettingsTab','notifications')">
                            <i class="fas fa-bell"></i>
                            <span>Notifications</span>
                        </a>
                        <div class="profile-dropdown-divider"></div>
                        <a href="@Url.Action("Logout", "Account")" class="profile-dropdown-item profile-dropdown-logout" onclick="return confirm('Are you sure you want to log out?');">
                            <i class="fas fa-right-from-bracket"></i>
                            <span>Log Out</span>
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            <!-- Notification Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" id="successAlert">
                    <i class="fas fa-check-circle"></i>
                    <span>@TempData["SuccessMessage"]</span>
                    <button class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error" id="errorAlert">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@TempData["ErrorMessage"]</span>
                    <button class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        // Auto-dismiss alerts after 5 seconds
        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                alert.style.animation = 'slideOut 0.3s ease forwards';
                setTimeout(function () { alert.remove(); }, 300);
            });
        }, 5000);

        // Open settings tab from sessionStorage
        document.addEventListener('DOMContentLoaded', function() {
            var tab = sessionStorage.getItem('openSettingsTab');
            if (tab) {
                sessionStorage.removeItem('openSettingsTab');
                // Will be handled by Profile page JS
            }
        });
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <div id="toastContainer" class="toast-container"></div>
    @RenderSection("Scripts", required: false)
</body>
</html>
