@model IEnumerable<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Product>
@{
    ViewData["Title"] = "Point of Sale";
    var categories = ViewData["Categories"] as List<string> ?? new List<string>();
    var customers = ViewData["Customers"] as List<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Customer> ?? new List<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Customer>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Point of Sale</h1>
        <p class="page-subtitle">Create new sales transactions</p>
    </div>
</div>

<div class="pos-layout">
    <!-- Product Grid -->
    <div class="pos-products">
        <div class="card">
            <div class="card-body">
                <div class="pos-search">
                    <i class="fas fa-search"></i>
                    <input type="text" id="posSearch" placeholder="Search products..." />
                </div>
                <div class="pos-categories" id="posCategories">
                    <button class="category-btn active" data-category="all">All</button>
                    @foreach (var cat in categories)
                    {
                        <button class="category-btn" data-category="@cat">@cat</button>
                    }
                </div>
                @if (Model.Any())
                {
                    <div class="pos-product-grid" id="posProductGrid">
                        @foreach (var product in Model)
                        {
                            <div class="pos-product-card" data-name="@product.ProductName" data-category="@product.Category" data-price="@product.Price" data-stock="@product.StockQuantity" onclick="addToCart('@product.ProductName.Replace("'", "\\'")','@product.Category', @product.Price, @product.StockQuantity, '@(product.ImagePath ?? "")')">
                                <div class="pos-product-image">
                                    @if (!string.IsNullOrEmpty(product.ImagePath))
                                    {
                                        <img src="@product.ImagePath" alt="@product.ProductName" />
                                    }
                                    else
                                    {
                                        <div class="pos-product-placeholder"><i class="fas fa-image"></i></div>
                                    }
                                </div>
                                <div class="pos-product-info">
                                    <span class="pos-product-category">@product.Category</span>
                                    <h4 class="pos-product-name">@product.ProductName</h4>
                                    <div class="pos-product-meta">
                                        <span class="pos-product-price">₱@product.Price.ToString("N0")</span>
                                        <span class="pos-product-stock">@product.StockQuantity left</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-boxes-stacked"></i>
                        <p>No products available. <a href="@Url.Action("Create", "Product")">Add products</a> to start selling.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Cart -->
    <div class="pos-cart">
        <div class="card">
            <div class="card-header">
                <h2><i class="fas fa-shopping-cart"></i> Current Order</h2>
                <span id="cartItemCount" class="text-muted">0 items</span>
            </div>
            <div class="card-body cart-body">
                <form id="checkoutForm" method="post" action="@Url.Action("Checkout", "Sale")">
                    @Html.AntiForgeryToken()

                    <!-- Customer Name Input -->
                    <div class="cart-customer-section">
                        <label class="cart-customer-label">
                            <i class="fas fa-user"></i> Customer Name
                        </label>
                        <div class="cart-customer-input-wrapper">
                            <input type="text" name="customerName" id="customerNameInput"
                                   class="form-control" placeholder="Type customer name or select below..."
                                   autocomplete="off" list="customerSuggestions" />
                            <datalist id="customerSuggestions">
                                @foreach (var c in customers)
                                {
                                    <option value="@c.Name">@c.Name</option>
                                }
                            </datalist>
                        </div>
                        <div class="cart-customer-quick">
                            <button type="button" class="customer-quick-btn active" onclick="setCustomerName('', this)">
                                <i class="fas fa-walking"></i> Walk-in
                            </button>
                            @foreach (var c in customers.Take(3))
                            {
                                <button type="button" class="customer-quick-btn" onclick="setCustomerName('@c.Name.Replace("'", "\\'")', this)">
                                    <i class="fas fa-user"></i> @(c.Name.Length > 10 ? c.Name.Substring(0, 10) + "…" : c.Name)
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Cart Items -->
                    <div class="cart-items" id="cartItems">
                        <div class="cart-empty" id="cartEmpty">
                            <i class="fas fa-shopping-cart"></i>
                            <p>No items in cart</p>
                            <span>Click products to add them</span>
                        </div>
                    </div>

                    <!-- Totals -->
                    <div class="cart-totals">
                        <div class="cart-total-row">
                            <span>Subtotal</span>
                            <span id="cartSubtotal">₱0</span>
                        </div>
                        <div class="cart-total-row">
                            <span>VAT (12%)</span>
                            <span id="cartVat">₱0.00</span>
                        </div>
                        <div class="cart-total-row cart-grand-total">
                            <span>Total</span>
                            <span id="cartTotal">₱0.00</span>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="cart-payment">
                        <label>Payment Method</label>
                        <div class="payment-methods">
                            <label class="payment-option active">
                                <input type="radio" name="paymentMethod" value="Cash" checked /> <i class="fas fa-money-bill-wave"></i> Cash
                            </label>
                            <label class="payment-option">
                                <input type="radio" name="paymentMethod" value="GCash" /> <i class="fas fa-mobile-screen-button"></i> GCash
                            </label>
                            <label class="payment-option">
                                <input type="radio" name="paymentMethod" value="Card" /> <i class="fas fa-credit-card"></i> Card
                            </label>
                        </div>
                    </div>

                    <input type="hidden" name="cartItems" id="cartItemsJson" />

                    <!-- Checkout Button -->
                    <button type="button" class="btn btn-primary btn-block" id="checkoutBtn" disabled onclick="handleCheckout()">
                        <i class="fas fa-check"></i> Checkout
                    </button>

                    <!-- Clear Cart Button -->
                    <button type="button" class="btn btn-outline btn-block" id="clearCartBtn" style="margin-top:8px; display:none;" onclick="clearCart()">
                        <i class="fas fa-trash"></i> Clear Cart
                    </button>
                </form>
            </div>
        </div>

        <!-- Order Summary (shows after items added) -->
        <div class="card" id="orderSummaryCard" style="display:none;">
            <div class="card-header">
                <h2><i class="fas fa-receipt"></i> Order Preview</h2>
            </div>
            <div class="card-body">
                <div id="orderPreviewList"></div>
            </div>
        </div>
    </div>
</div>

<!-- Checkout Success Modal -->
<div class="modal-overlay" id="checkoutModal">
    <div class="modal-content" style="max-width: 460px;">
        <div class="modal-body" style="text-align: center; padding: 40px 30px;">
            <div style="width:72px; height:72px; border-radius:50%; background:rgba(16,185,129,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size: 2rem; color: #10b981;">
                <i class="fas fa-check-circle"></i>
            </div>
            <h2 style="margin-bottom: 8px; font-size: 1.4rem;">Order Completed!</h2>
            <p style="color: var(--text-secondary); margin-bottom: 16px;" id="checkoutModalMessage">Your sale has been processed successfully.</p>
            <div style="background: var(--bg); border-radius: var(--radius); padding: 14px; margin-bottom: 20px; text-align: left;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                    <span style="color: var(--text-secondary);">Customer</span>
                    <strong id="modalCustomer">Walk-in</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                    <span style="color: var(--text-secondary);">Items</span>
                    <strong id="modalItemsCount">0</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                    <span style="color: var(--text-secondary);">Payment</span>
                    <strong id="modalPayment">Cash</strong>
                </div>
                <div style="display: flex; justify-content: space-between; border-top: 1px solid var(--border); padding-top: 8px; margin-top: 8px;">
                    <span style="color: var(--text); font-weight: 700;">Total</span>
                    <strong style="color: var(--primary); font-size: 1.1rem;" id="modalTotal">₱0.00</strong>
                </div>
            </div>
            <div style="display: flex; gap: 10px;">
                <a href="@Url.Action("Orders", "Sale")" class="btn btn-outline" style="flex:1;">
                    <i class="fas fa-clipboard-list"></i> View Orders
                </a>
                <button type="button" class="btn btn-primary" style="flex:1;" onclick="closeCheckoutModal()">
                    <i class="fas fa-plus"></i> New Sale
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];

        function addToCart(name, category, price, stock, image) {
            const existing = cart.find(i => i.ProductName === name);
            if (existing) {
                if (existing.Quantity >= stock) {
                    showToast('Not enough stock for ' + name + '!', 'warning');
                    return;
                }
                existing.Quantity++;
            } else {
                cart.push({ ProductName: name, Price: price, Quantity: 1, MaxStock: stock, Image: image });
            }
            renderCart();
            // Flash animation on the product card
            var cards = document.querySelectorAll('.pos-product-card');
            cards.forEach(function (c) {
                if (c.dataset.name === name) {
                    c.classList.add('pos-product-added');
                    setTimeout(function () { c.classList.remove('pos-product-added'); }, 300);
                }
            });
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
        }

        function updateQuantity(index, delta) {
            cart[index].Quantity += delta;
            if (cart[index].Quantity <= 0) {
                cart.splice(index, 1);
            } else if (cart[index].Quantity > cart[index].MaxStock) {
                cart[index].Quantity = cart[index].MaxStock;
                showToast('Maximum stock reached!', 'warning');
            }
            renderCart();
        }

        function setCustomerName(name, btn) {
            document.getElementById('customerNameInput').value = name;
            document.querySelectorAll('.customer-quick-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
        }

        function clearCart() {
            if (!confirm('Are you sure you want to clear the cart?')) return;
            cart = [];
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cartItems');
            const countEl = document.getElementById('cartItemCount');
            const subtotalEl = document.getElementById('cartSubtotal');
            const vatEl = document.getElementById('cartVat');
            const totalEl = document.getElementById('cartTotal');
            const btn = document.getElementById('checkoutBtn');
            const clearBtn = document.getElementById('clearCartBtn');
            const jsonInput = document.getElementById('cartItemsJson');
            const summaryCard = document.getElementById('orderSummaryCard');
            const previewList = document.getElementById('orderPreviewList');

            if (cart.length === 0) {
                container.innerHTML = '<div class="cart-empty" id="cartEmpty"><i class="fas fa-shopping-cart"></i><p>No items in cart</p><span>Click products to add them</span></div>';
                countEl.textContent = '0 items';
                subtotalEl.textContent = '₱0';
                vatEl.textContent = '₱0.00';
                totalEl.textContent = '₱0.00';
                btn.disabled = true;
                clearBtn.style.display = 'none';
                jsonInput.value = '';
                summaryCard.style.display = 'none';
                return;
            }

            let html = '';
            let previewHtml = '';
            let subtotal = 0;
            cart.forEach((item, i) => {
                const itemTotal = item.Price * item.Quantity;
                subtotal += itemTotal;
                html += `
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <span class="cart-item-name">${item.ProductName}</span>
                            <span class="cart-item-price">₱${item.Price.toLocaleString()} each</span>
                        </div>
                        <div class="cart-item-controls">
                            <button type="button" class="qty-btn" onclick="updateQuantity(${i}, -1)">−</button>
                            <span class="qty-value">${item.Quantity}</span>
                            <button type="button" class="qty-btn" onclick="updateQuantity(${i}, 1)">+</button>
                            <span class="cart-item-total">₱${itemTotal.toLocaleString()}</span>
                            <button type="button" class="cart-item-remove" onclick="removeFromCart(${i})"><i class="fas fa-xmark"></i></button>
                        </div>
                    </div>`;
                previewHtml += `<div style="display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid var(--border); font-size:0.88rem;">
                    <span>${item.Quantity}× ${item.ProductName}</span>
                    <strong>₱${itemTotal.toLocaleString()}</strong>
                </div>`;
            });

            container.innerHTML = html;
            const totalQty = cart.reduce((s, i) => s + i.Quantity, 0);
            countEl.textContent = totalQty + ' item' + (totalQty !== 1 ? 's' : '');

            const vat = subtotal * 0.12;
            const total = subtotal + vat;
            subtotalEl.textContent = '₱' + subtotal.toLocaleString();
            vatEl.textContent = '₱' + vat.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            totalEl.textContent = '₱' + total.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            btn.disabled = false;
            clearBtn.style.display = '';
            jsonInput.value = JSON.stringify(cart.map(i => ({ ProductName: i.ProductName, Quantity: i.Quantity, Price: i.Price })));

            // Show preview
            summaryCard.style.display = '';
            previewList.innerHTML = previewHtml;
        }

        function handleCheckout() {
            var customerName = document.getElementById('customerNameInput').value.trim();
            var totalQty = cart.reduce(function(s, i) { return s + i.Quantity; }, 0);
            var subtotal = cart.reduce(function(s, i) { return s + (i.Price * i.Quantity); }, 0);
            var total = subtotal + (subtotal * 0.12);
            var paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

            // Populate the modal
            document.getElementById('modalCustomer').textContent = customerName || 'Walk-in Customer';
            document.getElementById('modalItemsCount').textContent = totalQty + ' item' + (totalQty !== 1 ? 's' : '');
            document.getElementById('modalPayment').textContent = paymentMethod;
            document.getElementById('modalTotal').textContent = '₱' + total.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            // Show confirmation modal
            var modal = document.getElementById('checkoutModal');
            modal.style.display = 'flex';

            // Change the modal to confirmation mode
            var modalBody = modal.querySelector('.modal-body');
            var icon = modalBody.querySelector('div > i');
            icon.className = 'fas fa-cart-shopping';
            icon.parentElement.style.background = 'rgba(253,126,20,0.1)';
            icon.parentElement.style.color = 'var(--primary)';
            modalBody.querySelector('h2').textContent = 'Confirm Checkout?';
            modalBody.querySelector('p').textContent = 'Please review your order before completing.';

            // Update buttons
            var btnContainer = modalBody.querySelector('div:last-child');
            btnContainer.innerHTML = `
                <button type="button" class="btn btn-outline" style="flex:1;" onclick="closeCheckoutModal()">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" style="flex:1;" onclick="confirmCheckout()">
                    <i class="fas fa-check"></i> Confirm & Pay
                </button>`;
        }

        function confirmCheckout() {
            // Switch to processing state
            var modal = document.getElementById('checkoutModal');
            var modalBody = modal.querySelector('.modal-body');
            var icon = modalBody.querySelector('div > i');
            icon.className = 'fas fa-spinner fa-spin';
            icon.parentElement.style.background = 'rgba(59,130,246,0.1)';
            icon.parentElement.style.color = 'var(--info)';
            modalBody.querySelector('h2').textContent = 'Processing...';
            modalBody.querySelector('p').textContent = 'Completing your sale, please wait.';
            var btnContainer = modalBody.querySelector('div:last-child');
            btnContainer.innerHTML = '';

            // Submit the form
            document.getElementById('checkoutForm').submit();
        }

        function closeCheckoutModal() {
            document.getElementById('checkoutModal').style.display = 'none';
        }

        // Show toast (from site.js)
        function showToast(msg, type) {
            if (typeof window.Toast !== 'undefined') {
                window.Toast.show(msg, type);
            } else {
                var container = document.getElementById('toastContainer');
                if (!container) return;
                var t = document.createElement('div');
                t.className = 'toast toast-' + (type || 'info');
                t.innerHTML = '<i class="fas fa-' + (type === 'warning' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle') + '"></i> ' + msg;
                container.appendChild(t);
                setTimeout(function () { t.style.animation = 'toastSlideOut 0.3s ease forwards'; setTimeout(function () { t.remove(); }, 300); }, 3000);
            }
        }

        // Search
        document.getElementById('posSearch').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('.pos-product-card').forEach(card => {
                const name = card.dataset.name.toLowerCase();
                card.style.display = name.includes(q) ? '' : 'none';
            });
        });

        // Category filter
        document.querySelectorAll('.category-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                const cat = this.dataset.category;
                document.querySelectorAll('.pos-product-card').forEach(card => {
                    card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
                });
            });
        });

        // Payment method toggle
        document.querySelectorAll('.payment-option input').forEach(radio => {
            radio.addEventListener('change', function () {
                document.querySelectorAll('.payment-option').forEach(l => l.classList.remove('active'));
                this.parentElement.classList.add('active');
            });
        });

        // Customer name input — deselect quick buttons when typing
        document.getElementById('customerNameInput').addEventListener('input', function () {
            document.querySelectorAll('.customer-quick-btn').forEach(b => b.classList.remove('active'));
            if (this.value.trim() === '') {
                document.querySelector('.customer-quick-btn').classList.add('active');
            }
        });
    </script>
}
