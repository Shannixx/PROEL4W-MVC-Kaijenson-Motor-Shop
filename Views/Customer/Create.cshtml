@model PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Customer
@{
    ViewData["Title"] = Model.CustomerId == 0 ? "Add Customer" : "Edit Customer";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">@(Model.CustomerId == 0 ? "Add a new customer to your database" : "Update customer information")</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="@(Model.CustomerId == 0 ? "Create" : "Edit")">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerId" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="TotalPurchases" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" placeholder="Full name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+63 9XX XXX XXXX" />
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="LastVisit"></label>
                    <input asp-for="LastVisit" type="date" class="form-control" />
                </div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Index")" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Customer</button>
            </div>
        </form>
    </div>
</div>
