@model IEnumerable<PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Customer>
@{
    ViewData["Title"] = "Customers";
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalItems = (int)(ViewData["TotalItems"] ?? 0);
    var searchString = ViewData["SearchString"]?.ToString() ?? "";
    var totalRevenue = Model.Sum(c => c.TotalPurchases);
    var avgPurchase = Model.Any() ? totalRevenue / Model.Count() : 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Customers</h1>
        <p class="page-subtitle">Manage your customer database</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-export" onclick="exportCustomers()"><i class="fas fa-file-excel"></i> Export</button>
        <a href="@Url.Action("Create")" class="btn btn-primary"><i class="fas fa-plus"></i> Add Customer</a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid-3">
    <div class="stat-card-icon">
        <div class="sci-icon blue"><i class="fas fa-users"></i></div>
        <div>
            <div class="sci-label">Total Customers</div>
            <div class="sci-value">@totalItems</div>
        </div>
    </div>
    <div class="stat-card-icon">
        <div class="sci-icon green"><i class="fas fa-peso-sign"></i></div>
        <div>
            <div class="sci-label">Total Revenue</div>
            <div class="sci-value green-text">₱@totalRevenue.ToString("N0")</div>
        </div>
    </div>
    <div class="stat-card-icon">
        <div class="sci-icon orange"><i class="fas fa-receipt"></i></div>
        <div>
            <div class="sci-label">Avg. Purchase</div>
            <div class="sci-value">₱@avgPurchase.ToString("N0")</div>
        </div>
    </div>
</div>

<!-- Search -->
<div class="card" style="margin-bottom: 16px;">
    <div class="card-body" style="padding: 14px 22px;">
        <form method="get" class="filter-bar">
            <div class="filter-search">
                <i class="fas fa-search"></i>
                <input type="text" name="searchString" value="@searchString" placeholder="Search customers..." class="form-control" />
            </div>
            <button type="submit" class="btn btn-outline"><i class="fas fa-search"></i> Search</button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a href="@Url.Action("Index")" class="btn btn-outline btn-clear"><i class="fas fa-times"></i> Clear</a>
            }
        </form>
    </div>
</div>

<!-- Bulk Action Bar -->
<div class="bulk-action-bar" id="bulkActionBar">
    <div class="bulk-info">
        <i class="fas fa-check-square"></i>
        <span><span class="count" id="selectedCount">0</span> customer(s) selected</span>
    </div>
    <div class="bulk-actions">
        <button class="btn-bulk" onclick="BulkSelect.deselectAll()">Deselect All</button>
        <form method="post" action="@Url.Action("BulkDelete", "Customer")" id="bulkDeleteForm" onsubmit="return confirmBulkDelete()">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ids" id="bulkDeleteIds" />
            <button type="submit" class="btn-bulk btn-bulk-delete">
                <i class="fas fa-trash"></i> Delete (<span id="deleteSelectedCount">0</span>)
            </button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2><i class="fas fa-users"></i> Customers (@totalItems)</h2>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:40px;">
                                <input type="checkbox" class="header-checkbox" onchange="BulkSelect.toggleAll(this, '.row-checkbox')" />
                            </th>
                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Total Purchases</th>
                            <th>Last Visit</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="row-checkbox" data-id="@c.CustomerId"
                                           onchange="BulkSelect.toggle('@c.CustomerId', this)" />
                                </td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar-sm">
                                            @(c.Name.Split(' ').Length > 1 ? $"{c.Name.Split(' ')[0][0]}{c.Name.Split(' ')[1][0]}" : c.Name.Substring(0, Math.Min(2, c.Name.Length)).ToUpper())
                                        </div>
                                        <span>@c.Name</span>
                                    </div>
                                </td>
                                <td>@(c.Phone ?? "—")</td>
                                <td>@(c.Email ?? "—")</td>
                                <td><strong>₱@c.TotalPurchases.ToString("N2")</strong></td>
                                <td style="color: var(--text-secondary);">@(c.LastVisit?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td>
                                    <div class="action-buttons">
                                        <a href="@Url.Action("Edit", new { id = c.CustomerId })" class="action-btn action-edit" title="Edit"><i class="fas fa-pen"></i></a>
                                        <form method="post" action="@Url.Action("Delete", new { id = c.CustomerId })" style="display:inline;" onsubmit="return confirm('Delete this customer?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-btn action-delete" title="Delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    <span class="pagination-info">Page @currentPage of @totalPages</span>
                    <div class="pagination-links">
                        @if (currentPage > 1)
                        {
                            <a href="@Url.Action("Index", new { page = currentPage - 1, searchString })" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
                        }
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a href="@Url.Action("Index", new { page = i, searchString })" class="pagination-btn @(i == currentPage ? "active" : "")">@i</a>
                        }
                        @if (currentPage < totalPages)
                        {
                            <a href="@Url.Action("Index", new { page = currentPage + 1, searchString })" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <p>No customers found. <a href="@Url.Action("Create")">Add your first customer</a></p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function exportCustomers() {
            var data = [];
            @foreach (var c in Model)
            {
                <text>
                data.push({
                    'Name': '@Html.Raw(c.Name.Replace("'", "\\'"))',
                    'Phone': '@(c.Phone ?? "")',
                    'Email': '@(c.Email ?? "")',
                    'Total Purchases': @c.TotalPurchases.ToString("F2", System.Globalization.CultureInfo.InvariantCulture),
                    'Last Visit': '@(c.LastVisit?.ToString("yyyy-MM-dd") ?? "")'
                });
                </text>
            }
            exportToExcel(data, 'Customers', 'Customers-' + todayISO() + '.xlsx', [25, 15, 25, 16, 14]);
        }

        function confirmBulkDelete() {
            var ids = BulkSelect.getIds();
            if (ids.length === 0) return false;
            if (!confirm('Delete ' + ids.length + ' customer(s)?')) return false;
            document.getElementById('bulkDeleteIds').value = ids.join(',');
            return true;
        }
    </script>
}
