@model PROEL4W_MVC_Kaijenson_Motor_Shop.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back! Here's your shop overview.</p>
    </div>
</div>

<!-- Real-time Monitoring Panel -->
<div class="monitoring-panel">
    <div class="monitor-card monitor-blue">
        <div class="monitor-header">
            <span class="monitor-label">Products Scanned</span>
            <span class="monitor-live"><span class="monitor-live-dot"></span> LIVE</span>
        </div>
        <div class="monitor-value" id="monitorScanned">@Model.TotalProducts</div>
        <div class="monitor-subtitle">Total products tracked</div>
    </div>
    <div class="monitor-card monitor-green">
        <div class="monitor-header">
            <span class="monitor-label">Items Sold Today</span>
            <span class="monitor-live"><span class="monitor-live-dot"></span> LIVE</span>
        </div>
        <div class="monitor-value" id="monitorSold">0</div>
        <div class="monitor-subtitle">Units sold today</div>
    </div>
    <div class="monitor-card monitor-purple">
        <div class="monitor-header">
            <span class="monitor-label">Active Sessions</span>
            <span class="monitor-live"><span class="monitor-live-dot"></span> LIVE</span>
        </div>
        <div class="monitor-value" id="monitorSessions">1</div>
        <div class="monitor-subtitle">Current online users</div>
    </div>
    <div class="monitor-card monitor-orange">
        <div class="monitor-header">
            <span class="monitor-label">System Sync</span>
            <span class="monitor-live"><span class="monitor-live-dot"></span> LIVE</span>
        </div>
        <div class="monitor-value" id="monitorSync" style="color: var(--success);">✓</div>
        <div class="monitor-subtitle" id="monitorSyncText">Synced just now</div>
    </div>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-content">
            <p class="stat-label">Today's Sales</p>
            <h3 class="stat-value">₱@Model.TodaysSales.ToString("N0")</h3>
            <div class="stat-change positive">
                <i class="fas fa-trending-up"></i>
                <span>vs last month</span>
            </div>
        </div>
        <div class="stat-icon stat-icon-green">
            <i class="fas fa-peso-sign"></i>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-content">
            <p class="stat-label">Total Orders</p>
            <h3 class="stat-value">@Model.TotalOrders</h3>
            <div class="stat-change positive">
                <span>vs last month</span>
            </div>
        </div>
        <div class="stat-icon stat-icon-blue">
            <i class="fas fa-shopping-cart"></i>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-content">
            <p class="stat-label">Total Units</p>
            <h3 class="stat-value">@Model.TotalUnits</h3>
            <div class="stat-change neutral">
                <span>@Model.LowStockCount alerts vs last month</span>
            </div>
        </div>
        <div class="stat-icon stat-icon-yellow">
            <i class="fas fa-cubes"></i>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-content">
            <p class="stat-label">Stock Value</p>
            <h3 class="stat-value">₱@Model.StockValue.ToString("N0")</h3>
            <div class="stat-change neutral">
                <span>Retail vs last month</span>
            </div>
        </div>
        <div class="stat-icon stat-icon-purple">
            <i class="fas fa-warehouse"></i>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-chart-area"></i> Stock Movement (In vs Out)</h2>
            <span class="text-muted">Last 7 days</span>
        </div>
        <div class="card-body">
            <canvas id="stockMovementChart" height="260"></canvas>
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-chart-bar"></i> Stock Level by Category</h2>
        </div>
        <div class="card-body">
            <canvas id="stockCategoryChart" height="260"></canvas>
        </div>
    </div>
</div>

<!-- Low Stock & Recent Transactions Row -->
<div class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-exclamation-triangle"></i> Low Stock Alerts</h2>
        </div>
        <div class="card-body">
            @if (Model.LowStockAlerts.Any())
            {
                <div class="low-stock-list">
                    @foreach (var item in Model.LowStockAlerts)
                    {
                        <div class="low-stock-item">
                            <div class="low-stock-info">
                                <span class="low-stock-name">@item.ProductName</span>
                                <span class="low-stock-detail">Stock: @item.StockQuantity / Min: @item.MinStock</span>
                            </div>
                            <div class="low-stock-progress">
                                <div class="progress-bar">
                                    @{
                                        var pct = item.MinStock > 0 ? Math.Min(100, (int)((double)item.StockQuantity / item.MinStock * 100)) : 0;
                                        var color = pct < 30 ? "var(--danger)" : pct < 60 ? "var(--warning)" : "var(--success)";
                                    }
                                    <div class="progress-fill" style="width: @(pct)%; background: @color;"></div>
                                </div>
                                <span class="low-stock-need">Need: @(Math.Max(0, item.MinStock - item.StockQuantity)) units</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state-sm">
                    <i class="fas fa-check-circle" style="color: var(--success);"></i>
                    <p>All stock levels are healthy</p>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-receipt"></i> Recent Transactions</h2>
            <a href="@Url.Action("Orders", "Sale")" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="card-body">
            @if (Model.RecentTransactions.Any())
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Order</th>
                                <th>Customer</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>#@sale.SaleId</td>
                                    <td>@sale.CustomerName</td>
                                    <td>₱@sale.Total.ToString("N2")</td>
                                    <td>
                                        <span class="status-badge status-@sale.Status.ToLower()">
                                            @sale.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state-sm">
                    <i class="fas fa-inbox"></i>
                    <p>No transactions yet</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Recent Products & Activity Row -->
<div class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-clock"></i> Recent Products</h2>
            <a href="@Url.Action("Index", "Product")" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="card-body">
            @if (Model.RecentProducts.Any())
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.RecentProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="product-cell">
                                            @if (!string.IsNullOrEmpty(product.ImagePath))
                                            {
                                                <img src="@product.ImagePath" alt="@product.ProductName" class="product-thumb" />
                                            }
                                            else
                                            {
                                                <div class="product-thumb-placeholder">
                                                    <i class="fas fa-image"></i>
                                                </div>
                                            }
                                            <span>@product.ProductName</span>
                                        </div>
                                    </td>
                                    <td>@product.Category</td>
                                    <td>₱@product.Price.ToString("N2")</td>
                                    <td>@product.StockQuantity</td>
                                    <td>
                                        <span class="status-badge status-@product.Status.ToLower().Replace(" ", "-")">
                                            @product.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No products yet. <a href="@Url.Action("Create", "Product")">Add your first product</a></p>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-history"></i> Recent Activity</h2>
        </div>
        <div class="card-body">
            @if (Model.RecentLogs.Any())
            {
                <div class="activity-list">
                    @foreach (var log in Model.RecentLogs)
                    {
                        <div class="activity-item">
                            <div class="activity-icon">
                                @switch (log.Action)
                                {
                                    case "Login":
                                        <i class="fas fa-right-to-bracket" style="color: #10b981;"></i>
                                        break;
                                    case "Logout":
                                        <i class="fas fa-right-from-bracket" style="color: #6b7280;"></i>
                                        break;
                                    case "Create Product":
                                        <i class="fas fa-plus-circle" style="color: #3b82f6;"></i>
                                        break;
                                    case "Edit Product":
                                        <i class="fas fa-pen" style="color: #f59e0b;"></i>
                                        break;
                                    case "Delete Product":
                                        <i class="fas fa-trash" style="color: #ef4444;"></i>
                                        break;
                                    case "New Sale":
                                        <i class="fas fa-shopping-cart" style="color: #10b981;"></i>
                                        break;
                                    default:
                                        <i class="fas fa-circle-info" style="color: #8b5cf6;"></i>
                                        break;
                                }
                            </div>
                            <div class="activity-content">
                                <p>@log.Details</p>
                                <span class="activity-time">
                                    <i class="fas fa-clock"></i> @log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-history"></i>
                    <p>No activity recorded yet</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Stock Movement Chart
        const movementData = @Html.Raw(Model.StockMovementJson ?? "[]");
        if (movementData.length > 0) {
            new Chart(document.getElementById('stockMovementChart'), {
                type: 'line',
                data: {
                    labels: movementData.map(d => d.date),
                    datasets: [
                        {
                            label: 'Stock In',
                            data: movementData.map(d => d.stockIn),
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.1)',
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Stock Out',
                            data: movementData.map(d => d.stockOut),
                            borderColor: '#ef4444',
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            fill: true,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }

        // Stock by Category Chart
        const categoryData = @Html.Raw(Model.StockByCategoryJson ?? "[]");
        if (categoryData.length > 0) {
            new Chart(document.getElementById('stockCategoryChart'), {
                type: 'bar',
                data: {
                    labels: categoryData.map(d => d.category),
                    datasets: [{
                        label: 'Units',
                        data: categoryData.map(d => d.total),
                        backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444', '#06b6d4', '#f97316'],
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }

        // Real-time Monitoring Simulation
        (function() {
            var soldEl = document.getElementById('monitorSold');
            var sessionsEl = document.getElementById('monitorSessions');
            var syncEl = document.getElementById('monitorSyncText');
            var soldCount = 0;

            setInterval(function() {
                if (Math.random() > 0.6) {
                    soldCount += Math.floor(Math.random() * 3) + 1;
                    if (soldEl) soldEl.textContent = soldCount;
                }
            }, 3000);

            setInterval(function() {
                var sessions = Math.floor(Math.random() * 3) + 1;
                if (sessionsEl) sessionsEl.textContent = sessions;
            }, 5000);

            setInterval(function() {
                if (syncEl) {
                    var now = new Date();
                    syncEl.textContent = 'Synced at ' + now.toLocaleTimeString();
                }
            }, 8000);
        })();
    </script>
}
