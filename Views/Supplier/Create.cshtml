@model PROEL4W_MVC_Kaijenson_Motor_Shop.Models.Supplier
@{
    ViewData["Title"] = Model.SupplierId == 0 ? "Add Supplier" : "Edit Supplier";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">@(Model.SupplierId == 0 ? "Add a new supplier" : "Update supplier information")</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="@(Model.SupplierId == 0 ? "Create" : "Edit")">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SupplierId" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" placeholder="Supplier name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Contact"></label>
                    <input asp-for="Contact" class="form-control" placeholder="Contact person" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+63 9XX XXX XXXX" />
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="email@supplier.com" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Categories"></label>
                    <input asp-for="Categories" class="form-control" placeholder="e.g. Engine Oil, Tires" />
                </div>
                <div class="form-group">
                    <label asp-for="Status"></label>
                    <select asp-for="Status" class="form-control">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Index")" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Supplier</button>
            </div>
        </form>
    </div>
</div>
