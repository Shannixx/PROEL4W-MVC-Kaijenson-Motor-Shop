@model PROEL4W_MVC_Kaijenson_Motor_Shop.Models.User
@{
    ViewData["Title"] = "Delete User";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Delete User</h1>
        <p class="page-subtitle">Are you sure you want to delete this user?</p>
    </div>
</div>

<div class="card delete-card">
    <div class="card-body">
        <div class="delete-warning">
            <div class="delete-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>Confirm Deletion</h3>
            <p>You are about to delete the following user. This action cannot be undone.</p>
        </div>

        <div class="delete-details">
            <div class="detail-row">
                <label>Full Name:</label>
                <span>@Model.FullName</span>
            </div>
            <div class="detail-row">
                <label>Email:</label>
                <span>@Model.Email</span>
            </div>
            <div class="detail-row">
                <label>Role:</label>
                <span class="role-badge role-@Model.Role.ToLower()">@Model.Role</span>
            </div>
            <div class="detail-row">
                <label>Joined:</label>
                <span>@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="UserId" />
            <div class="form-actions">
                <a href="@Url.Action("Index")" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Delete User
                </button>
            </div>
        </form>
    </div>
</div>
