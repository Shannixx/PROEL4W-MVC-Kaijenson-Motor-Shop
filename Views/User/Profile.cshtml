@model PROEL4W_MVC_Kaijenson_Motor_Shop.Models.User
@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Settings</h1>
        <p class="page-subtitle">Manage your account and application preferences</p>
    </div>
</div>

<div class="settings-layout">
    <!-- Settings Tabs -->
    <div class="card" style="height: fit-content;">
        <div class="card-body" style="padding: 12px;">
            <div class="settings-tabs">
                <button class="settings-tab active" onclick="switchSettingsTab('account')">
                    <i class="fas fa-user"></i> Account
                </button>
                <button class="settings-tab" onclick="switchSettingsTab('shop')">
                    <i class="fas fa-store"></i> Shop Info
                </button>
                <button class="settings-tab" onclick="switchSettingsTab('notifications')">
                    <i class="fas fa-bell"></i> Notifications
                </button>
                <button class="settings-tab" onclick="switchSettingsTab('security')">
                    <i class="fas fa-shield-halved"></i> Security
                </button>
            </div>
        </div>
    </div>

    <!-- Settings Panels -->
    <div>
        <!-- Account Tab -->
        <div class="settings-panel active" id="panel-account">
            <div class="card">
                <div class="card-header">
                    <h2><i class="fas fa-user-edit"></i> Account Settings</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Profile" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                        <input type="hidden" asp-for="UserId" />

                        <div class="form-section">
                            <h3><i class="fas fa-camera"></i> Profile Photo</h3>
                            <div class="profile-upload">
                                <div class="profile-upload-preview">
                                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                                    {
                                        <img id="profilePreview" src="@Model.ProfileImage" alt="Profile" />
                                    }
                                    else
                                    {
                                        <img id="profilePreview" style="display:none;" />
                                        <div id="profilePlaceholder" class="profile-upload-placeholder">
                                            <i class="fas fa-camera"></i>
                                        </div>
                                    }
                                </div>
                                <div class="profile-upload-info">
                                    <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('imageFile').click()">
                                        <i class="fas fa-upload"></i> Upload Photo
                                    </button>
                                    <p>JPG, PNG or GIF. Max 5MB.</p>
                                    <input type="file" name="imageFile" id="imageFile" accept="image/*" onchange="previewProfileImage(this)" style="display:none;" />
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3><i class="fas fa-info-circle"></i> Personal Information</h3>
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="FirstName">First Name <span class="required">*</span></label>
                                    <input asp-for="FirstName" class="form-control" />
                                    <span asp-validation-for="FirstName" class="field-validation"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="LastName">Last Name <span class="required">*</span></label>
                                    <input asp-for="LastName" class="form-control" />
                                    <span asp-validation-for="LastName" class="field-validation"></span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label asp-for="Email">Email Address <span class="required">*</span></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="field-validation"></span>
                            </div>
                            <div class="form-group">
                                <label>Login Email</label>
                                <input type="text" class="form-control" value="@Model.Email" disabled style="background: var(--bg);" />
                                <span style="font-size:0.78rem; color:var(--text-light);">Login email is managed through the Account tab</span>
                            </div>
                            <div class="form-group">
                                <label>Role</label>
                                <span class="role-badge role-@Model.Role.ToLower()">@Model.Role</span>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Shop Info Tab -->
        <div class="settings-panel" id="panel-shop">
            <div class="card">
                <div class="card-header">
                    <h2><i class="fas fa-store"></i> Shop Information</h2>
                </div>
                <div class="card-body">
                    <div class="form-section">
                        <h3><i class="fas fa-info-circle"></i> Business Details</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Shop Name</label>
                                <input type="text" class="form-control" value="Kaijenson Motor Shop" />
                            </div>
                            <div class="form-group">
                                <label>Owner</label>
                                <input type="text" class="form-control" value="@Model.FullName" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Phone</label>
                                <input type="text" class="form-control" value="+63 912 345 6789" />
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" class="form-control" value="info@kaijenson.com" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Address</label>
                            <textarea class="form-control" rows="2">Kaijenson Motor Shop, Philippines</textarea>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3><i class="fas fa-calculator"></i> Tax & Finance</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Tax Rate (%)</label>
                                <input type="number" class="form-control" value="12" min="0" max="100" step="0.5" />
                            </div>
                            <div class="form-group">
                                <label>Currency</label>
                                <input type="text" class="form-control" value="PHP (₱)" disabled style="background: var(--bg);" />
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-primary" onclick="showToast('Shop info saved!', 'success')">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Tab -->
        <div class="settings-panel" id="panel-notifications">
            <div class="card">
                <div class="card-header">
                    <h2><i class="fas fa-bell"></i> Notification Preferences</h2>
                </div>
                <div class="card-body">
                    <div class="setting-row">
                        <div class="setting-row-info">
                            <p>Low Stock Alerts</p>
                            <span>Get notified when products reach minimum stock level</span>
                        </div>
                        <button class="toggle-switch active" onclick="this.classList.toggle('active')"></button>
                    </div>
                    <div class="setting-row">
                        <div class="setting-row-info">
                            <p>New Order Notifications</p>
                            <span>Receive alerts for every new POS transaction completed</span>
                        </div>
                        <button class="toggle-switch active" onclick="this.classList.toggle('active')"></button>
                    </div>
                    <div class="setting-row">
                        <div class="setting-row-info">
                            <p>Daily Sales Summary</p>
                            <span>Get a daily summary of total sales and transactions</span>
                        </div>
                        <button class="toggle-switch" onclick="this.classList.toggle('active')"></button>
                    </div>
                    <div class="setting-row">
                        <div class="setting-row-info">
                            <p>System Updates</p>
                            <span>Receive notifications about system updates and maintenance</span>
                        </div>
                        <button class="toggle-switch active" onclick="this.classList.toggle('active')"></button>
                    </div>
                    <div class="setting-row">
                        <div class="setting-row-info">
                            <p>Customer Activity</p>
                            <span>Get notified about new customer registrations</span>
                        </div>
                        <button class="toggle-switch" onclick="this.classList.toggle('active')"></button>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-primary" onclick="showToast('Notification preferences saved!', 'success')">
                            <i class="fas fa-save"></i> Save Preferences
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Security Tab -->
        <div class="settings-panel" id="panel-security">
            <div class="card">
                <div class="card-header">
                    <h2><i class="fas fa-shield-halved"></i> Security</h2>
                </div>
                <div class="card-body">
                    <div class="form-section">
                        <h3><i class="fas fa-key"></i> Change Password</h3>
                        <form asp-action="ChangePassword" method="post">
                            <div class="form-group">
                                <label>Current Password <span class="required">*</span></label>
                                <div class="password-wrapper">
                                    <input type="password" name="CurrentPassword" class="form-control" required />
                                    <button type="button" class="password-toggle" onclick="togglePasswordVisibility(this)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>New Password <span class="required">*</span></label>
                                    <div class="password-wrapper">
                                        <input type="password" name="NewPassword" class="form-control" required minlength="6" />
                                        <button type="button" class="password-toggle" onclick="togglePasswordVisibility(this)">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Confirm New Password <span class="required">*</span></label>
                                    <div class="password-wrapper">
                                        <input type="password" name="ConfirmPassword" class="form-control" required minlength="6" />
                                        <button type="button" class="password-toggle" onclick="togglePasswordVisibility(this)">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-key"></i> Update Password
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="form-section" style="margin-top: 28px;">
                        <h3><i class="fas fa-circle-info"></i> Account Information</h3>
                        <div style="background: var(--bg); border-radius: var(--radius); padding: 16px;">
                            <div class="detail-row">
                                <label>Account Created</label>
                                <span>@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
                            </div>
                            <div class="detail-row">
                                <label>Account Role</label>
                                <span class="role-badge role-@Model.Role.ToLower()">@Model.Role</span>
                            </div>
                            <div class="detail-row">
                                <label>Login Email</label>
                                <span>@Model.Email</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function switchSettingsTab(tabId) {
            // Deactivate all tabs and panels
            document.querySelectorAll('.settings-tab').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });

            // Activate selected
            var panel = document.getElementById('panel-' + tabId);
            if (panel) panel.classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function previewProfileImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var preview = document.getElementById('profilePreview');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    var placeholder = document.getElementById('profilePlaceholder');
                    if (placeholder) placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function togglePasswordVisibility(btn) {
            var input = btn.previousElementSibling;
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<i class="fas fa-eye"></i>';
            }
        }
    </script>
}
